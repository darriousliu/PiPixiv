## 6. 分页功能开发规范

新的分页列表功能必须使用 **Paging 3**：

```kotlin
// ✅ 新增 PagingSource（放在 common/repository/.../paging/ 目录）
class NewFeaturePagingSource(
    private val param: String,
) : PagingSource<Map<String, String>, Item>() {

    override fun getRefreshKey(state: PagingState<Map<String, String>, Item>): Map<String, String>? = null

    override suspend fun load(params: LoadParams<Map<String, String>>): LoadResult<Map<String, String>, Item> {
        return try {
            val resp = if (params.key == null) {
                PixivRepository.getNewData(param)
            } else {
                PixivRepository.loadMoreNewData(params.key!!)
            }
            LoadResult.Page(
                data = resp.items,
                prevKey = null,
                nextKey = resp.nextUrl?.parseQueryParams()
            )
        } catch (e: Exception) {
            LoadResult.Error(e)
        }
    }
}

// ✅ 在 ViewModel 中声明 Flow
val items = Pager(PagingConfig(pageSize = 20)) {
    NewFeaturePagingSource(param)
}.flow.cachedIn(viewModelScope)

// ✅ 在 Composable 中收集
val lazyItems = viewModel.items.collectAsLazyPagingItems()
```

